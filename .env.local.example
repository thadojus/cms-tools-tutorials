# Builder.io Configuration
# Get your API key from: https://builder.io/account/organization
NEXT_PUBLIC_BUILDER_API_KEY=your-builder-api-key-here

# Optional: Builder.io Private Key (for admin operations)
BUILDER_PRIVATE_KEY=your-private-key-here

# Example API for external integrations
NEXT_PUBLIC_EXAMPLE_API_URL=https://jsonplaceholder.typicode.com

# Authentication (for demo purposes)
NEXTAUTH_SECRET=your-nextauth-secret
NEXTAUTH_URL=http://localhost:3000
